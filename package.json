{
  "name": "fluiddified",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fluiddified — a Klipper web interface, forked from Fluidd.",
  "author": {
    "name": "Fluiddified Contributors"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite",
    "serve": "vite",
    "build:server": "npx tsc -p tsconfig.server.json",
    "serve:proxy": "node --import tsx server/index.ts",
    "serve:prod": "npm run build && node --import tsx server/index.ts",
    "serve:docs": "cd ./docs && zensical serve",
    "lint": "eslint .",
    "bootstrap": "husky",
    "release": "commit-and-tag-version",
    "release:major": "npm run release -- --release-as major",
    "release:minor": "npm run release -- --release-as minor",
    "release:patch": "npm run release -- --release-as patch",
    "release:rc": "npm run release -- --prerelease rc",
    "test": "npm run test:unit",
    "test:unit": "vitest --environment jsdom --config ./vitest.config.ts",
    "test:e2e": "playwright test",
    "type-check": "vue-tsc --build --noEmit",
    "circular-check": "skott --displayMode=file-tree --showCircularDependencies --no-trackTypeOnlyDependencies --tsconfig=./tsconfig.app.json",
    "theme:convert": "cd tools; node convertTheme.mjs"
  },
  "main": "index.js",
  "dependencies": {
    "@ctrl/tinycolor": "^4.2.0",
    "@fastify/http-proxy": "^11.4.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/reply-from": "^12.6.1",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@irojs/iro-core": "^1.2.1",
    "@jaames/iro": "^5.5.2",
    "axios": "^1.14.0",
    "consola": "^3.4.2",
    "dompurify": "^3.3.3",
    "echarts": "^5.6.0",
    "echarts-gl": "^2.0.9",
    "fastify": "^5.8.4",
    "fflate": "^0.8.2",
    "hls.js": "^1.6.15",
    "ipaddr.js": "^2.3.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.17.23",
    "marked": "^17.0.5",
    "marked-base-url": "^1.1.8",
    "md5": "^2.3.0",
    "monaco-editor": "^0.55.1",
    "panzoom": "^9.4.4",
    "path-browserify": "^1.0.1",
    "qr-scanner": "^1.4.2",
    "qrcode.vue": "^1.7.0",
    "semver": "^7.7.4",
    "shlex": "^3.0.0",
    "sortablejs": "^1.15.7",
    "three": "^0.170.0",
    "uuid": "^13.0.0",
    "vue": "^2.7.16",
    "vue-class-component": "^7.2.6",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^8.28.2",
    "vue-inline-svg": "^2.1.4",
    "vue-json-viewer": "^2.2.22",
    "vue-meta": "^2.4.0",
    "vue-property-decorator": "^9.1.2",
    "vue-router": "^3.6.5",
    "vue-virtual-scroller": "^1.1.2",
    "vue2-touch-events": "^3.2.3",
    "vuetify": "^2.7.2",
    "vuetify-confirm": "^2.0.6",
    "vuex": "^3.6.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@originjs/vite-plugin-content": "^1.0.5",
    "@pedrolamas/plugin-vue2": "^2.4.0",
    "@playwright/test": "^1.59.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "@types/sortablejs": "^1.15.9",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.18.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^1.3.6",
    "@vue/tsconfig": "^0.9.1",
    "commit-and-tag-version": "^12.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "mockdate": "^3.0.5",
    "monaco-vscode-textmate-theme-converter": "^0.1.7",
    "neostandard": "^0.13.0",
    "rollup": "^4.60.1",
    "sass-embedded": "^1.98.0",
    "skott": "^0.35.9",
    "svgo": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^8.0.3",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "vue-debounce-decorator": "^1.0.1",
    "vue-template-compiler": "^2.7.16",
    "vue-tsc": "~3.0.8",
    "workbox-build": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-recipes": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "bugs": {
    "url": "https://github.com/revoxxi/fluiddified/issues"
  },
  "homepage": "https://github.com/revoxxi/fluiddified#readme",
  "keywords": [
    "klipper",
    "fluiddified",
    "fluidd"
  ],
  "license": "GPL-3.0",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revoxxi/fluiddified.git"
  },
  "overrides": {
    "@vue/tsconfig": {
      "vue": "$vue"
    },
    "glob": "^13.0.6",
    "monaco-editor": {
      "dompurify": "$dompurify"
    },
    "serialize-javascript": "^7.0.3",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "engines": {
    "node": "^22.12.0 || ^24"
  }
}
